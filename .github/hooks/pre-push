#!/bin/sh
# Run the full test suite before every push.
# Exit non-zero to abort the push if any test fails.

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "→ Running tests before push..."
make test
STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo ""
  echo "✗ Tests failed — push aborted. Fix the failures and try again."
  exit 1
fi

echo "✓ All tests passed."
